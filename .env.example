# ──────────────────────────────────────────
#  Ethiopian Job Bot — Environment Variables
# ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER put real credentials in this file — it is committed to git.

# ── Telegram ───────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# The channel ID to broadcast to.
# For public channels: @your_channel_name
# For private channels: -100xxxxxxxxxx (use @userinfobot to get it)
TELEGRAM_CHAT_ID=@your_channel_here

# ── Scheduler ──────────────────────────────
# Cron expression for how often to run the pipeline
# Default: every 6 hours
SCRAPE_CRON=0 */6 * * *

# ── Scraper Behavior ───────────────────────
# Max jobs to process per portal per run (prevents flooding)
MAX_JOBS_PER_PORTAL=50

# Request timeout in milliseconds
REQUEST_TIMEOUT_MS=15000

# Delay between requests in ms (be polite to servers)
REQUEST_DELAY_MS=2000
